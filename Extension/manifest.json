{
    "manifest_version": 3,
    "name": "Clickbait Hilighter",
    "version": "3.0",
    "description": "在新聞網頁中偵測、標記誘餌標題，並在tooltip中顯示更新後的標題",
    "permissions": ["activeTab"],
    "host_permissions": ["<all_urls>"],
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["https://*/*"],
        "js": ["content.js"]
      }
    ],
    "web_accessible_resources": [
      {
        "resources": ["model.js"],
        "matches": ["<all_urls>"]
      }
    ]
  }