# Classifier mode:
# mock  = keyword-based fallback for local development
# model = Hugging Face transformer classifier
CLASSIFIER_MODE=model
CLASSIFIER_MODEL_NAME=Stremie/xlm-roberta-base-clickbait

# Gemini API settings for context-aware headline rewriting
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash-lite

CLICKBAIT_THRESHOLD=0.7
MAX_CANDIDATES=100
MAX_REWRITES=5