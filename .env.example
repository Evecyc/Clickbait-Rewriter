# Gemini API key for future headline rewriting.
# Leave empty if rewrite is not enabled.
GEMINI_API_KEY=

# Backend settings
CLICKBAIT_THRESHOLD=0.7
MAX_CANDIDATES=100
MAX_REWRITES=5

# Classifier mode:
# mock  = keyword-based demo fallback
# model = Hugging Face transformer classifier
CLASSIFIER_MODE=mock
CLASSIFIER_MODEL_NAME=Stremie/xlm-roberta-base-clickbait